APP_NAME=Laravel
APP_ENV=local
APP_KEY=base64:AgCnHwjRaXuXBorif5LIPkBMko+bomQ/v5vdhaxAmIw=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# =====================
# DATABASE (DIMATIIN)
# =====================
DB_CONNECTION=null
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

# =====================
# SESSION (PAKE FILE)
# =====================
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# =====================
# QUEUE (NON DB)
# =====================
QUEUE_CONNECTION=sync

# =====================
# CACHE (NON DB)
# =====================
CACHE_STORE=file
# CACHE_PREFIX=

# =====================
# FILESYSTEM
# =====================
FILESYSTEM_DISK=local

# =====================
# BROADCAST
# =====================
BROADCAST_CONNECTION=log

# =====================
# MEMCACHED (IGNORE)
# =====================
MEMCACHED_HOST=127.0.0.1

# =====================
# REDIS (IGNORE)
# =====================
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# =====================
# MAIL (LOG MODE)
# =====================
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# =====================
# AWS (KOSONGIN AJA)
# =====================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# =====================
# VITE
# =====================
VITE_APP_NAME="${APP_NAME}"
